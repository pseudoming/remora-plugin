{
  "remora": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/zombie-detector.py",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/snapshot-git.py",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/session-guardian.py",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/tone-injector.py",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/cognitive-push.py --stage=pre-invoke",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/sandbox/check-subagents-liveness.py",
        "timeout": 30
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/zombie-detector.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "run_command|view_file|grep_search|write_to_file|multi_replace_file_content|replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/safety-check.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "write_to_file|multi_replace_file_content|replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/cognitive-push.py --stage=pre-tool",
            "timeout": 30
          }
        ]
      }
    ],
    "PostInvocation": [
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/hooks/action-gate.py",
        "timeout": 30
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/sidecar/compactor/compactor.py --event-driven",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/maintenance/clean-session-stats.py",
        "timeout": 15
      },
      {
        "type": "command",
        "command": "{PYTHON} {PLUGIN_ROOT}/scripts/adapter/sandbox/check-subagents-liveness.py",
        "timeout": 30
      }
    ]
  }
}