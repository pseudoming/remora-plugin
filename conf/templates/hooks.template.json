{
  "remora": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/zombie-detector.ts",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/snapshot-git.ts",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/session-guardian.ts",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/tone-injector.ts",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/cognitive-push.ts --stage=pre-invoke",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/sandbox/check-subagents-liveness.ts",
        "timeout": 30
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/zombie-detector.ts",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "run_command|view_file|grep_search|write_to_file|multi_replace_file_content|replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/safety-check.ts",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "write_to_file|multi_replace_file_content|replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/cognitive-push.ts --stage=pre-tool",
            "timeout": 30
          }
        ]
      }
    ],
    "PostInvocation": [
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/hooks/action-gate.ts",
        "timeout": 30
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/sidecar/compactor.ts --event-driven",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/maintenance/clean-session-stats.ts",
        "timeout": 15
      },
      {
        "type": "command",
        "command": "npx tsx {PLUGIN_ROOT}/packages/adapter-antigravity/src/sandbox/check-subagents-liveness.ts",
        "timeout": 30
      }
    ]
  }
}
